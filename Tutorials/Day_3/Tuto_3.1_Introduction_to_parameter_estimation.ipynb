      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Rejection Sampling:\n",
            "f = 1.941 +/- 0.040\n",
            "alpha = 0.346 +/- 0.016\n",
            "\n",
            "bilby_mcmc:\n",
            "f = 1.941 +/- 0.039\n",
            "alpha = 0.346 +/- 0.016\n"
          ]
        }
      ],
      "source": [
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import bilby\n",
        "import corner\n",
        "\n",
        "# Rejection sampling statistics\n",
        "mean_f_rs = np.mean(freq_samples)\n",
        "std_f_rs = np.std(freq_samples)\n",
        "mean_alpha_rs = np.mean(alpha_samples)\n",
        "std_alpha_rs = np.std(alpha_samples)\n",
        "\n",
        "print(\"Rejection Sampling:\")\n",
        "print(f\"f = {mean_f_rs:.3f} +/- {std_f_rs:.3f}\")\n",
        "print(f\"alpha = {mean_alpha_rs:.3f} +/- {std_alpha_rs:.3f}\")\n",
        "\n",
        "# bilby_mcmc statistics\n",
        "mean_f_mcmc = np.mean(result_Ms.posterior[\"freq\"])\n",
        "std_f_mcmc = np.std(result_Ms.posterior[\"freq\"])\n",
        "mean_alpha_mcmc = np.mean(result_Ms.posterior[\"alpha\"])\n",
        "std_alpha_mcmc = np.std(result_Ms.posterior[\"alpha\"])\n",
        "\n",
        "print(\"\\nbilby_mcmc:\")\n",
        "print(f\"f = {mean_f_mcmc:.3f} +/- {std_f_mcmc:.3f}\")\n",
        "print(f\"alpha = {mean_alpha_mcmc:.3f} +/- {std_alpha_mcmc:.3f}\")"
      ]
    },
    {
